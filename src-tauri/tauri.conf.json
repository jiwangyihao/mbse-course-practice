{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MBSE 建模工作台",
  "version": "0.1.0",
  "identifier": "top.jwyihao.mbse-course-practice",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": "node scripts/prepare-tauri-bundle.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MBSE 建模工作台",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": ["icons/icon.ico"],
    "windows": {
      "minimumWebview2Version": "119.0.0.0",
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      }
    },
    "externalBin": ["bin/mbse-agent-sidecar"],
    "resources": {
      "resources/mbse-sidecar/": "mbse-sidecar"
    }
  }
}
