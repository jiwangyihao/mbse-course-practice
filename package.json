{
  "name": "mbse-course-practice",
  "version": "0.1.0",
  "private": true,
  "description": "基于 Tauri 的 MBSE 建模工作台课程大实践",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:contract": "vitest run tests/project-contract.test.ts",
    "typecheck": "tsc --noEmit",
    "bundle:prepare": "node scripts/prepare-tauri-bundle.mjs",
    "bundle:verify-sidecar": "node scripts/verify-bundled-sidecar.mjs",
    "bundle:inspect": "node scripts/inspect-tauri-bundle.mjs",
    "tauri": "node scripts/run-tauri.mjs",
    "tauri:dev": "node scripts/run-tauri.mjs dev",
    "tauri:build": "node scripts/run-tauri.mjs build --no-bundle",
    "tauri:bundle": "node scripts/run-tauri.mjs build"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@oh-my-pi/pi-coding-agent": "^16.3.15",
    "@tauri-apps/api": "^2.5.0",
    "@xyflow/react": "^12.8.2",
    "antd": "^6.5.0",
    "elkjs": "^0.10.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sysml-v2-lsp": "^0.23.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-sysml": "^0.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
